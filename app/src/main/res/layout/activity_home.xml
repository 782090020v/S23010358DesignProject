<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/X06"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical"
    tools:context=".HomeActivity">

    <!-- Top App Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_splash"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/M01"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vms_main_dashboard"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.02" />

        <!-- Nav tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/L01"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/bg_nav_item"
                android:text="@string/nav_dashboard"
                android:textSize="11sp"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <View android:layout_width="8dp" android:layout_height="1dp" />

            <TextView
                android:id="@+id/L03"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/bg_nav_item"
                android:text="@string/nav_new_request"
                android:textSize="11sp"
                android:textColor="#BBDEFB"
                android:textStyle="bold" />

            <View android:layout_width="8dp" android:layout_height="1dp" />

            <TextView
                android:id="@+id/M04"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/bg_nav_item"
                android:text="@string/nav_admin"
                android:textSize="11sp"
                android:textColor="#BBDEFB"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- PENDING REQUESTS SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:elevation="2dp">

                <!-- Section header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@color/colorStatusPending"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/M05"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/things_to_do"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary" />
                </LinearLayout>

                <!-- Table Header Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:background="@color/colorPrimary"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:id="@+id/X02"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/ticket_id"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/X03"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.2"
                        android:gravity="center"
                        android:text="@string/location"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/X04"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.2"
                        android:gravity="center"
                        android:text="@string/work_type"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/X05"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.1"
                        android:gravity="center"
                        android:text="@string/start_date"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/X07"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.1"
                        android:gravity="center"
                        android:text="@string/end_date"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/X01"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/request_status"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Sample data row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="#FAFCFF"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/x"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:gravity="center"
                        android:textSize="10sp"
                        android:textColor="@color/colorTextPrimary"
                        android:hint="--"
                        android:inputType="text" />

                    <EditText
                        android:id="@+id/Y02"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.2"
                        android:background="@null"
                        android:gravity="center"
                        android:textSize="10sp"
                        android:textColor="@color/colorTextPrimary"
                        android:hint="--"
                        android:inputType="text" />

                    <EditText
                        android:id="@+id/Y03"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.2"
                        android:background="@null"
                        android:gravity="center"
                        android:textSize="10sp"
                        android:textColor="@color/colorTextPrimary"
                        android:hint="--"
                        android:inputType="text" />

                    <EditText
                        android:id="@+id/Y04"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.1"
                        android:background="@null"
                        android:gravity="center"
                        android:textSize="10sp"
                        android:textColor="@color/colorTextPrimary"
                        android:hint="--"
                        android:inputType="date" />

                    <EditText
                        android:id="@+id/Y05"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.1"
                        android:background="@null"
                        android:gravity="center"
                        android:textSize="10sp"
                        android:textColor="@color/colorTextPrimary"
                        android:hint="--"
                        android:inputType="date" />

                    <TextView
                        android:id="@+id/Y06"
                        android:layout_width="0dp"
                        android:layout_height="26dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/status_pending"
                        android:textSize="9sp"
                        android:textColor="@color/colorStatusPending"
                        android:textStyle="bold"
                        android:background="@drawable/bg_status_pending" />
                </LinearLayout>

                <!-- Empty state -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="@string/no_records"
                    android:textSize="12sp"
                    android:textColor="@color/colorTextHint"
                    android:visibility="gone" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorDivider" />

                <View android:layout_width="1dp" android:layout_height="12dp" />

            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="20dp" />

            <!-- LIVE WORK PERMITS SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@color/colorStatusLive"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/Z01"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/live_work_permits"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary" />
                </LinearLayout>

                <!-- Table Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:background="@color/colorStatusLive"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp">

                    <TextView
                        android:id="@+id/Z02"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/ticket_id"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/Z03"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.2"
                        android:gravity="center"
                        android:text="@string/location"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/Z04"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.2"
                        android:gravity="center"
                        android:text="@string/work_type"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/Z05"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.1"
                        android:gravity="center"
                        android:text="@string/start_date"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/Z06"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.1"
                        android:gravity="center"
                        android:text="@string/end_date"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/Z08"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/request_status"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Empty state row -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="@string/no_records"
                    android:textSize="12sp"
                    android:textColor="@color/colorTextHint" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorDivider" />

                <View android:layout_width="1dp" android:layout_height="12dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
