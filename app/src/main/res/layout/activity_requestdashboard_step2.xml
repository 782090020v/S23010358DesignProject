<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true"
    tools:context=".RequestDashboardStep2Activity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header + Nav -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_splash"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vms_main_dashboard"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tabDashboard"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_nav_item"
                    android:gravity="center"
                    android:text="@string/nav_dashboard"
                    android:textColor="#BBDEFB"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <TextView
                    android:id="@+id/tabAccessRequest"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_nav_item"
                    android:gravity="center"
                    android:text="@string/nav_access_request"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <TextView
                    android:id="@+id/tabAdmin"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_nav_item"
                    android:gravity="center"
                    android:text="@string/nav_admin"
                    android:textColor="#BBDEFB"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Form Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:text="@string/request_form_title"
                android:textColor="@color/colorPrimary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- Division -->
            <TextView
                style="@style/TextStyle.SectionHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/label_division" />

            <EditText
                android:id="@+id/etDivision"
                style="@style/InputStyle"
                android:hint="@string/hint_division"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:singleLine="true" />

            <!-- Responsible Person -->
            <TextView
                style="@style/TextStyle.SectionHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp"
                android:text="@string/label_responsible_person" />

            <EditText
                android:id="@+id/etResponsiblePerson"
                style="@style/InputStyle"
                android:hint="@string/hint_responsible_person"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:singleLine="true" />

            <!-- Work Description -->
            <TextView
                style="@style/TextStyle.SectionHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp"
                android:text="@string/label_work_description" />

            <EditText
                android:id="@+id/etWorkDescription"
                style="@style/InputStyle"
                android:layout_height="100dp"
                android:hint="@string/hint_work_description"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:paddingTop="12dp" />

            <!-- Add Visitor Button -->
            <Button
                android:id="@+id/btnAddVisitor"
                style="@style/ButtonStyle.Primary"
                android:layout_marginTop="24dp"
                android:text="@string/btn_add_visitor" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
