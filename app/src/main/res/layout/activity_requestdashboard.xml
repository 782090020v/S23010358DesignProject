<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true"
    tools:context=".RequestdashboardActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header + Nav -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_splash"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vms_main_dashboard"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tabDashboard"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_nav_item"
                    android:gravity="center"
                    android:text="@string/nav_dashboard"
                    android:textColor="#BBDEFB"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <TextView
                    android:id="@+id/tabAccessRequest"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_nav_item"
                    android:gravity="center"
                    android:text="@string/nav_access_request"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <TextView
                    android:id="@+id/tabAdmin"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_nav_item"
                    android:gravity="center"
                    android:text="@string/nav_admin"
                    android:textColor="#BBDEFB"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Form Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:text="@string/request_form_title"
                android:textColor="@color/colorPrimary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- Requester -->
            <TextView
                style="@style/TextStyle.SectionHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="@string/label_requester" />

            <EditText
                android:id="@+id/etRequester"
                style="@style/InputStyle"
                android:hint="@string/hint_requester"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:singleLine="true" />

            <!-- Responsible Person -->
            <TextView
                style="@style/TextStyle.SectionHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp"
                android:text="@string/label_responsible_person" />

            <EditText
                android:id="@+id/etResponsiblePerson"
                style="@style/InputStyle"
                android:hint="@string/hint_responsible_person"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:singleLine="true" />

            <!-- Location -->
            <TextView
                style="@style/TextStyle.SectionHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="6dp"
                android:text="@string/location" />

            <EditText
                android:id="@+id/etLocation"
                style="@style/InputStyle"
                android:hint="@string/hint_location"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:singleLine="true" />

            <!-- Access Start / Access End -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextStyle.SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/label_access_start" />

                    <EditText
                        android:id="@+id/etAccessStart"
                        style="@style/InputStyle"
                        android:hint="DD/MM/YYYY"
                        android:imeOptions="actionNext"
                        android:inputType="datetime"
                        android:singleLine="true" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextStyle.SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/label_access_end" />

                    <EditText
                        android:id="@+id/etAccessEnd"
                        style="@style/InputStyle"
                        android:hint="DD/MM/YYYY"
                        android:imeOptions="actionDone"
                        android:inputType="datetime"
                        android:singleLine="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- Work Type -->
            <TextView
                style="@style/TextStyle.SectionHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="8dp"
                android:text="@string/work_type_label" />

            <RadioGroup
                android:id="@+id/rgWorkType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbNewInstallation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:buttonTint="@color/colorPrimary"
                    android:text="@string/work_new_installation"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/rbMeeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:buttonTint="@color/colorPrimary"
                    android:text="@string/work_meeting"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/rbService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:buttonTint="@color/colorPrimary"
                    android:text="@string/work_service"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/rbRemovals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:buttonTint="@color/colorPrimary"
                    android:text="@string/work_removals"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/rbAdhoc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:buttonTint="@color/colorPrimary"
                    android:text="@string/work_adhoc"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/rbPlannedEvent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/colorPrimary"
                    android:text="@string/work_planned_event"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="13sp" />
            </RadioGroup>

            <!-- Next Button -->
            <Button
                android:id="@+id/btnNext"
                style="@style/ButtonStyle.Primary"
                android:layout_marginTop="24dp"
                android:text="@string/btn_next" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
